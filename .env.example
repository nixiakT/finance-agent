# Copy this file to .env.local and fill real credentials.
# Never commit .env.local.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# If your OpenAI-compatible gateway lists different models, use one from /v1/models.

# Optional CLI language: zh or en.
FINANCE_AGENT_LANG=zh

# Optional proxy for web/market-data lookups. Example for Clash/Mihomo:
# FINANCE_HTTP_PROXY=http://127.0.0.1:7897

# Optional WeChat/WeCom delivery.
# Default is dry-run: messages are written to .finance_agent/wechat_outbox.
FINANCE_WECHAT_MODE=dry-run
# FINANCE_WECHAT_WEBHOOK=<paste-full-wecom-webhook-url-in-.env.local>
# FINANCE_WECHAT_RELAY_URL=http://127.0.0.1:8765/wechat/send

ALPHAVANTAGE_API_KEY=
TUSHARE_TOKEN=
FINANCE_ALLOW_SAMPLE_FALLBACK=1
